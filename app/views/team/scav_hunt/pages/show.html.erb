<main>
  <h2>Page <%= @page_number %></h2>
  <p><%= link_to "(presenter view)", team_scav_hunt_page_presenter_path(@team_scav_hunt, @page_number) %></p>
  <h3>Page Captains</h3>
  <ul>
    <% @page_captains.each do |page_captain| %>
      <li>
        <%= page_captain.user.name %>
        <% if page_owner? || captain? %>
          <%= form_with model: page_captain, method: :DELETE, url: team_scav_hunt_page_path(@team_scav_hunt, @page_number), class: 'inline-form' do |form| %>
            <%= form.hidden_field :user_id %>
            <%= form.submit "❌", class: 'inline-button' %>
          <% end %>
        <% end %>
      </li>
    <% end %>
  </ul>
  <% if captain? %>
    <%= form_with model: @team_scav_hunt.page_captains.new, url: team_scav_hunt_pages_path(@team_scav_hunt), class: 'inline-form' do |form| %>
      <%= form.hidden_field :page_number, value: @page_number %>
      <%= form.label :user_id, "Add page captain:" %>
      <%= form.select :user_id, [["N/A", nil], *@team_users.map { |tu| [tu.user.name, tu.user.id] }] %>
      <%= form.submit "Add" %>
    <% end %>
  <% end %>
  <h3>Items</h3>
  <%= render "team/scav_hunt/items/list", items: @items %>
</main>
