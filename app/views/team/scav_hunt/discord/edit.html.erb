<h1>Set Up <%= @team_scav_hunt.name %> (<%= @team.affiliation %>)</h1>
<h3>Discord Linking</h3>
<% if @user.discord_id.nil? %>
  <p><%= link_to "Connect your discord account to configure", discord_connect_account_uri(team: @team, user: @user, path: edit_team_scav_hunt_discord_path(@team_scav_hunt)).to_s %></p>
<% else %>
  <%= form_with model: @team_scav_hunt, url: team_scav_hunt_discord_path(@team_scav_hunt) do |form| %>
    <%= form.label :discord_items_channel_id, "Items Channel ID:" %>
    <%= form.text_field :discord_items_channel_id %>
    <%= form.label :discord_pages_channel_id, "Pages Channel ID:" %>
    <%= form.text_field :discord_pages_channel_id %>
    <%= form.label :discord_guild_id, "Guild ID:" %>
    <%= form.text_field :discord_guild_id %>
    <%= form.submit "Update" %>
  <% end %>
<% end %>
